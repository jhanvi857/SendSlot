{
  "name": "sendslot-server",
  "version": "0.1.0",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:worker\"",
    "dev:api": "nodemon src/app.js",
    "dev:worker": "cross-env WORKER_PRIMARY=true nodemon src/workers/index.js",
    "start:api": "node src/app.js",
    "start:worker": "WORKER_PRIMARY=true node src/workers/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.394.0",
    "@aws-sdk/s3-request-presigner": "^3.394.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "bullmq": "^1.85.0",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^6.7.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^4.0.0",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.3",
    "postgres": "^3.1.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^2.0.22"
  }
}
