{
  "name": "sendslot-server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:worker\"",
    "dev:api": "tsx watch src/app.ts",
    "dev:worker": "cross-env WORKER_PRIMARY=true tsx watch src/workers/index.ts",
    "start:api": "node dist/app.js",
    "start:worker": "cross-env WORKER_PRIMARY=true node dist/workers/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.394.0",
    "@aws-sdk/s3-request-presigner": "^3.394.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "bullmq": "^1.85.0",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^6.7.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^4.0.0",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.3",
    "postgres": "^3.1.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "cross-env": "^7.0.3",
    "nodemon": "^2.0.22",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
